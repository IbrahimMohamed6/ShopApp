@model ShopApp.PL.ViewModels.AdminProductFormVM
@{ ViewData["Title"] = "Edit Product"; }

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-pencil me-2"></i>Edit Product</h2>
    <a asp-action="Index" class="btn btn-outline-secondary">← Back</a>
</div>

<div class="card shadow-sm" style="max-width:750px">
    <div class="card-body">
        <form asp-action="Edit" method="post" enctype="multipart/form-data">
            <input asp-for="ProductId" type="hidden" />
            <div class="row g-3">
                <div class="col-md-8">
                    <label asp-for="Name" class="form-label fw-semibold"></label>
                    <input asp-for="Name" class="form-control" />
                    <span asp-validation-for="Name" class="text-danger small"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="SKU" class="form-label fw-semibold"></label>
                    <input asp-for="SKU" class="form-control" />
                </div>
                <div class="col-md-4">
                    <label asp-for="Price" class="form-label fw-semibold"></label>
                    <div class="input-group">
                        <span class="input-group-text">$</span>
                        <input asp-for="Price" class="form-control" type="number" step="0.01" min="0.01" />
                    </div>
                </div>
                <div class="col-md-4">
                    <label asp-for="StockQuantity" class="form-label fw-semibold">Stock</label>
                    <input asp-for="StockQuantity" class="form-control" type="number" min="0" />
                </div>
                <div class="col-md-4">
                    <label asp-for="CategoryId" class="form-label fw-semibold">Category</label>
                    <select asp-for="CategoryId" class="form-select"
                            asp-items="@(new SelectList(Model.Categories, "CategoryId", "Name"))">
                    </select>
                </div>
                <div class="col-12">
                    <label asp-for="Description" class="form-label fw-semibold"></label>
                    <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                </div>
                <div class="col-md-9">
                    <label class="form-label fw-semibold">Product Image</label>
                    @if (!string.IsNullOrEmpty(Model.ImageUrl))
                    {
                        <div class="mb-2">
                            <img src="@Model.ImageUrl" alt="Current image"
                                 class="img-thumbnail" style="height:100px;object-fit:cover" />
                            <small class="text-muted d-block mt-1">Current image</small>
                        </div>
                    }
                    <input asp-for="ImageFile" type="file" accept="image/*" class="form-control" />
                    <input asp-for="ImageUrl" type="hidden" />
                    <small class="text-muted">Leave empty to keep the current image.</small>
                </div>
                <div class="col-md-3 d-flex align-items-end">
                    <div class="form-check mb-2">
                        <input asp-for="IsActive" class="form-check-input" type="checkbox" />
                        <label asp-for="IsActive" class="form-check-label">Active</label>
                    </div>
                </div>
            </div>
            <div class="d-flex gap-2 mt-4">
                <button class="btn btn-success px-4">
                    <i class="bi bi-save me-1"></i> Update
                </button>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>
