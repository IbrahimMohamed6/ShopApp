@model ShopApp.PL.ViewModels.AdminCategoryFormVM
@{ ViewData["Title"] = "Edit Category"; }

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-pencil me-2"></i>Edit Category</h2>
    <a asp-action="Index" class="btn btn-outline-secondary">← Back</a>
</div>

<div class="card shadow-sm" style="max-width:500px">
    <div class="card-body">
        <form asp-action="Edit" method="post">
            <input asp-for="CategoryId" type="hidden" />
            <div class="mb-3">
                <label asp-for="Name" class="form-label fw-semibold"></label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger small"></span>
            </div>
            <div class="mb-4">
                <label asp-for="ParentCategoryId" class="form-label fw-semibold">Parent Category</label>
                <select asp-for="ParentCategoryId" class="form-select"
                        asp-items="@(new SelectList(Model.AllCategories, "CategoryId", "Name"))">
                    <option value="">— Top-level category —</option>
                </select>
            </div>
            <div class="d-flex gap-2">
                <button class="btn btn-success px-4">
                    <i class="bi bi-save me-1"></i> Update
                </button>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>
