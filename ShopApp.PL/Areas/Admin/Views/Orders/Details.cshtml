@model ShopApp.PL.ViewModels.OrderDetailsVM
@{
    var o = Model.Order;
    ViewData["Title"] = $"Order {o.OrderNumber}";
    var badge = o.Status switch
    {
        ShopApp.DAL.Models.OrderStatus.Pending => "bg-warning text-dark",
        ShopApp.DAL.Models.OrderStatus.Processing => "bg-info text-dark",
        ShopApp.DAL.Models.OrderStatus.Shipped => "bg-primary",
        ShopApp.DAL.Models.OrderStatus.Delivered => "bg-success",
        ShopApp.DAL.Models.OrderStatus.Cancelled => "bg-danger",
        _ => "bg-secondary"
    };
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Order: <code>@o.OrderNumber</code></h2>
    <a asp-action="Index" class="btn btn-outline-secondary">← Back to Orders</a>
</div>

<div class="row g-4">
    <!-- Items -->
    <div class="col-md-8">
        <div class="card shadow-sm mb-3">
            <div class="card-header bg-dark text-white d-flex justify-content-between">
                <span><i class="bi bi-receipt me-2"></i>Order Items</span>
                <span class="badge @badge fs-6">@o.Status</span>
            </div>
            <div class="card-body p-0">
                <table class="table align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Product</th>
                            <th class="text-end">Price</th>
                            <th class="text-center">Qty</th>
                            <th class="text-end">Total</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in o.Items)
                        {
                            <tr>
                                <td>@item.ProductName</td>
                                <td class="text-end">$@item.UnitPrice.ToString("0.00")</td>
                                <td class="text-center">@item.Quantity</td>
                                <td class="text-end fw-semibold">$@item.LineTotal.ToString("0.00")</td>
                            </tr>
                        }
                    </tbody>
                    <tfoot>
                        <tr class="table-light fw-bold">
                            <td colspan="3">Total</td>
                            <td class="text-end text-success fs-5">$@o.TotalAmount.ToString("0.00")</td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </div>
    </div>

    <!-- Info panel -->
    <div class="col-md-4">
        <!-- Customer -->
        <div class="card shadow-sm mb-3">
            <div class="card-header bg-secondary text-white">Customer</div>
            <div class="card-body">
                <p class="mb-1"><strong>@(o.CustomerName ?? "—")</strong></p>
                <p class="text-muted small mb-0">@o.CustomerEmail</p>
                <p class="text-muted small">Placed: @o.OrderDate.ToString("MMM dd, yyyy HH:mm")</p>
            </div>
        </div>

        <!-- Shipping -->
        @if (o.ShippingAddress is not null)
        {
            <div class="card shadow-sm mb-3">
                <div class="card-header bg-secondary text-white">Shipping Address</div>
                <div class="card-body">
                    <address class="mb-0">
                        @o.ShippingAddress.Street<br />
                        @o.ShippingAddress.City, @o.ShippingAddress.Zip<br />
                        @o.ShippingAddress.Country
                    </address>
                </div>
            </div>
        }

        <!-- Update Status -->
        <div class="card shadow-sm">
            <div class="card-header bg-danger text-white fw-semibold">Update Status</div>
            <div class="card-body">
                <form asp-action="UpdateStatus" method="post">
                    <input type="hidden" name="OrderId" value="@o.OrderId" />
                    <div class="mb-3">
                        <select name="Status" class="form-select">
                            @foreach (var s in Enum.GetValues<ShopApp.DAL.Models.OrderStatus>())
                            {
                                <option value="@((int)s)" selected="@(o.Status == s ? "selected" : null)">@s</option>
                            }
                        </select>
                    </div>
                    <button class="btn btn-danger w-100">
                        <i class="bi bi-arrow-repeat me-1"></i> Update
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>