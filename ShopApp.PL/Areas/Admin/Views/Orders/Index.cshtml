@model ShopApp.PL.ViewModels.AdminOrderListVM
@{
    ViewData["Title"] = "Orders";
}
<h2 class="mb-4"><i class="bi bi-receipt me-2"></i>Orders</h2>

<!-- Status filter -->
<div class="mb-3 d-flex flex-wrap gap-2">
    <a asp-action="Index" class="btn btn-sm @(Model.FilterStatus == null ? "btn-dark" : "btn-outline-dark")">
        All
    </a>
    @foreach (var s in Enum.GetValues<ShopApp.DAL.Models.OrderStatus>())
    {
        <a asp-action="Index" asp-route-status="@((int)s)"
           class="btn btn-sm @(Model.FilterStatus == s ? "btn-dark" : "btn-outline-secondary")">
            @s
        </a>
    }
</div>

<div class="card shadow-sm">
    <div class="card-body p-0">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-dark">
                <tr>
                    <th>Order #</th>
                    <th>Customer</th>
                    <th>Date</th>
                    <th>Status</th>
                    <th class="text-end">Total</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var o in Model.Orders)
                {
                    var badge = o.Status switch
                    {
                        ShopApp.DAL.Models.OrderStatus.Pending => "bg-warning text-dark",
                        ShopApp.DAL.Models.OrderStatus.Processing => "bg-info text-dark",
                        ShopApp.DAL.Models.OrderStatus.Shipped => "bg-primary",
                        ShopApp.DAL.Models.OrderStatus.Delivered => "bg-success",
                        ShopApp.DAL.Models.OrderStatus.Cancelled => "bg-danger",
                        _ => "bg-secondary"
                    };
                    <tr>
                        <td><code class="text-primary">@o.OrderNumber</code></td>
                        <td>
                            <div>@(o.CustomerName ?? "—")</div>
                            <small class="text-muted">@o.CustomerEmail</small>
                        </td>
                        <td class="text-muted small">@o.OrderDate.ToString("MMM dd, yyyy")</td>
                        <td><span class="badge @badge">@o.Status</span></td>
                        <td class="text-end fw-semibold">$@o.TotalAmount.ToString("0.00")</td>
                        <td>
                            <a asp-action="Details" asp-route-id="@o.OrderId"
                               class="btn btn-outline-primary btn-sm">View</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>