@model ShopApp.PL.ViewModels.CartVM
@{
    ViewData["Title"] = "Shopping Cart";
    var cart = Model.Cart;
}

<h2 class="mb-4"><i class="bi bi-cart3 me-2"></i>Shopping Cart</h2>

@if (!cart.Items.Any())
{
    <div class="text-center py-5 text-muted">
        <i class="bi bi-cart-x d-block" style="font-size:4rem"></i>
        <p class="fs-5 mt-3">Your cart is empty.</p>
        <a asp-controller="Catalog" asp-action="Index" class="btn btn-primary mt-2">
            <i class="bi bi-arrow-left me-1"></i> Continue Shopping
        </a>
    </div>
}
else
{
    <div class="row g-4">
        <!-- Items table -->
        <div class="col-lg-8">
            <div class="card shadow-sm">
                <div class="card-body p-0">
                    <table class="table align-middle mb-0">
                        <thead class="table-dark">
                            <tr>
                                <th>Product</th>
                                <th class="text-end">Price</th>
                                <th class="text-center">Qty</th>
                                <th class="text-end">Total</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in cart.Items)
                            {
                                <tr>
                                    <td>
                                        <strong>@item.ProductName</strong>
                                    </td>
                                    <td class="text-end">$@item.UnitPrice.ToString("0.00")</td>
                                    <td class="text-center" style="width:130px">
                                        <form asp-action="Update" method="post" class="d-flex gap-1 justify-content-center">
                                            <input type="hidden" name="productId" value="@item.ProductId" />
                                            <input type="number" name="qty" value="@item.Quantity"
                                                   min="1" class="form-control form-control-sm text-center"
                                                   style="width:60px" />
                                            <button class="btn btn-outline-secondary btn-sm" title="Update">↺</button>
                                        </form>
                                    </td>
                                    <td class="text-end fw-bold">$@item.LineTotal.ToString("0.00")</td>
                                    <td class="text-center">
                                        <form asp-action="Remove" method="post">
                                            <input type="hidden" name="productId" value="@item.ProductId" />
                                            <button class="btn btn-outline-danger btn-sm">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
            <div class="d-flex justify-content-between mt-3">
                <a asp-controller="Catalog" asp-action="Index" class="btn btn-outline-secondary">
                    <i class="bi bi-arrow-left me-1"></i> Continue Shopping
                </a>
                <form asp-action="Clear" method="post">
                    <button class="btn btn-outline-danger">
                        <i class="bi bi-trash me-1"></i> Clear Cart
                    </button>
                </form>
            </div>
        </div>

        <!-- Summary -->
        <div class="col-lg-4">
            <div class="card shadow-sm">
                <div class="card-header bg-dark text-white fw-semibold">
                    <i class="bi bi-receipt me-1"></i> Order Summary
                </div>
                <div class="card-body">
                    <dl class="row mb-0">
                        <dt class="col-6">Items</dt>
                        <dd class="col-6 text-end">@cart.ItemCount</dd>
                        <dt class="col-6 border-top pt-2 fs-5">Total</dt>
                        <dd class="col-6 text-end border-top pt-2 fs-5 text-success fw-bold">
                            $@cart.Total.ToString("0.00")
                        </dd>
                    </dl>
                </div>
                <div class="card-footer">
                    <a asp-controller="Orders" asp-action="Checkout" class="btn btn-success w-100 btn-lg">
                        <i class="bi bi-credit-card me-2"></i>Checkout
                    </a>
                </div>
            </div>
        </div>
    </div>
}
