@model ShopApp.PL.ViewModels.OrderListVM
@{
    ViewData["Title"] = "My Orders";
}

<h2 class="mb-4"><i class="bi bi-bag me-2"></i>My Orders</h2>

@if (!Model.Orders.Any())
{
    <div class="text-center py-5 text-muted">
        <i class="bi bi-bag-x d-block" style="font-size:4rem"></i>
        <p class="fs-5 mt-3">No orders yet.</p>
        <a asp-controller="Catalog" asp-action="Index" class="btn btn-primary mt-2">Start Shopping</a>
    </div>
}
else
{
    <div class="card shadow-sm">
        <div class="card-body p-0">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>Order #</th>
                        <th>Date</th>
                        <th>Status</th>
                        <th class="text-end">Total</th>
                        <th>Ship To</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var o in Model.Orders)
                    {
                        <tr>
                            <td><code class="text-primary">@o.OrderNumber</code></td>
                            <td class="text-muted small">@o.OrderDate.ToString("MMM dd, yyyy")</td>
                            <td>
                                @{
                                    var badge = o.Status switch {
                                        ShopApp.DAL.Models.OrderStatus.Pending    => "bg-warning text-dark",
                                        ShopApp.DAL.Models.OrderStatus.Processing => "bg-info text-dark",
                                        ShopApp.DAL.Models.OrderStatus.Shipped    => "bg-primary",
                                        ShopApp.DAL.Models.OrderStatus.Delivered  => "bg-success",
                                        ShopApp.DAL.Models.OrderStatus.Cancelled  => "bg-danger",
                                        _ => "bg-secondary"
                                    };
                                }
                                <span class="badge @badge">@o.Status</span>
                            </td>
                            <td class="text-end fw-bold">$@o.TotalAmount.ToString("0.00")</td>
                            <td class="small text-muted">
                                @o.ShippingAddress?.City, @o.ShippingAddress?.Country
                            </td>
                            <td>
                                <a asp-action="Details" asp-route-id="@o.OrderId"
                                   class="btn btn-outline-primary btn-sm">View</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
