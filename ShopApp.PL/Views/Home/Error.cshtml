@{
    ViewData["Title"] = "Error";
    var customMessage = ViewData["ErrorMessage"] as string;
    var statusCode = Context.Response.StatusCode;
}

<div class="text-center mt-5 mb-5 py-5 bg-white rounded shadow-sm">
    @if (statusCode == 404)
    {
        <h1 class="display-1 text-warning mb-3"><i class="bi bi-file-earmark-x"></i></h1>
        <h2 class="text-warning fw-bold">Page Not Found</h2>
        <p class="lead text-muted mt-3">@(customMessage ?? "The page you are looking for does not exist.")</p>
    }
    else
    {
        <h1 class="display-1 text-danger mb-3"><i class="bi bi-exclamation-octagon"></i></h1>
        <h2 class="text-danger fw-bold">Unexpected Error</h2>
        <p class="lead text-muted mt-3">An error occurred while processing your request. Please try again later.</p>
    }
    <a asp-controller="Catalog" asp-action="Index" class="btn btn-primary mt-4 px-4 py-2">
        <i class="bi bi-house me-2"></i>Return to Homepage
    </a>
</div>
